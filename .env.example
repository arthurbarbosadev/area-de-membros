# Copie para .env.local e preencha com seus valores reais.
# Nunca suba .env.local — ele está no .gitignore.

# ── Supabase ──────────────────────────────────────────────────────────────
# Encontre em: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-publica

# Service role (nunca exponha no frontend)
# Encontre em: Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-secreta

# ── Painel Admin ──────────────────────────────────────────────────────────
# Chave que você vai digitar em /admin para entrar (mín. 32 chars aleatórios)
ADMIN_SECRET_KEY=gere-com--node-e--require-crypto-.randomBytes-32-.toString-base64url-

# Segredo HMAC para assinar o cookie de sessão admin (mín. 32 chars)
ADMIN_SESSION_SECRET=outro-valor-aleatorio-diferente-do-acima
